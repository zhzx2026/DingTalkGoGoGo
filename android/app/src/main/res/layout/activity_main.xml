<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical"
  android:background="@color/gd_background">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="20dp"
    android:paddingTop="16dp"
    android:paddingEnd="20dp"
    android:paddingBottom="12dp">

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:orientation="vertical">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/gd_text"
        android:textSize="20sp"
        android:textStyle="bold" />

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="@string/app_subtitle"
        android:textColor="@color/gd_muted"
        android:textSize="13sp" />
    </LinearLayout>

    <Button
      android:id="@+id/change_server_button"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:minHeight="0dp"
      android:paddingHorizontal="14dp"
      android:paddingVertical="8dp"
      android:text="@string/change_server_button" />
  </LinearLayout>

  <ProgressBar
    android:id="@+id/loading_indicator"
    style="?android:attr/progressBarStyleHorizontal"
    android:layout_width="match_parent"
    android:layout_height="3dp"
    android:indeterminate="true"
    android:visibility="gone" />

  <LinearLayout
    android:id="@+id/config_panel"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    android:background="@color/gd_surface"
    android:elevation="2dp"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="@string/server_title"
      android:textColor="@color/gd_text"
      android:textSize="18sp"
      android:textStyle="bold" />

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:text="@string/server_hint"
      android:textColor="@color/gd_muted"
      android:textSize="14sp" />

    <EditText
      android:id="@+id/server_url_input"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="16dp"
      android:autofillHints="url"
      android:background="@android:drawable/edit_text"
      android:hint="@string/server_placeholder"
      android:imeOptions="actionDone"
      android:inputType="textUri"
      android:maxLines="1"
      android:padding="14dp" />

    <Button
      android:id="@+id/save_server_button"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="16dp"
      android:text="@string/open_console_button" />
  </LinearLayout>

  <WebView
    android:id="@+id/web_view"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1" />

</LinearLayout>
